# Reliquary runtime environment — generated by setup_miner.sh

# Network / chain
export BT_NETWORK=finney
export NETUID=81

# Wallet
export BT_WALLET_NAME=ronnywebdev
export BT_HOTKEY=hdev0301

# Base model. The validator may push fine-tuned checkpoints over HF;
# this is the cold-start default if the validator isn't reachable yet.
export RELIQUARY_CHECKPOINT=Qwen/Qwen3-4B-Instruct-2507

# Attention. Validator runs FlashAttention 2 (confirmed 2026-05-26). vLLM
# 0.20.2 already auto-selects FLASH_ATTN backend on Blackwell sm_120
# (see miner.log: "Using FlashAttention version 2"). We now match it on
# the HF sketch path too. flash-attn proper has no prebuilt wheel for
# torch 2.11+cu130+py3.12+sm_120; transformers 5.8 auto-falls-back to
# `kernels-community/flash-attn2` from the HF kernels hub when the
# `kernels` package is installed and the local flash_attn is missing.
# Switching sketch from sdpa→fa2 should collapse the sketch_diff_max
# tail that drives bad_termination rejections.
export RELIQUARY_ATTN_IMPL=flash_attention_2
export GRAIL_ATTN_IMPL=flash_attention_2

# HF token to pull published checkpoints from the validator's HF repo.
export HF_TOKEN=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
export HUGGING_FACE_HUB_TOKEN=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

# Pin paths
export RELIQUARY_INSTALL_DIR=/root/reliquary
export RELIQUARY_VENV=/root/.venv

# Max generation length. Pin to the protocol cap (8192) to give every
# rollout the same budget the validator's verify_termination would
# accept on Path 1. Cap-hits still cost us a truncation count in
# steady-state (MAX_TRUNCATED_PER_SUBMISSION=0), but lowering the
# miner-side cap can't help with that — it only shrinks the EOS-discovery
# window for rollouts that would have terminated between (lower-cap, 8192).
export RELIQUARY_MAX_NEW_TOKENS=8192

# Drand
export RELIQUARY_USE_DRAND=1

# Validator URL — pinned during the subnet-launch phase. After the
# owner validator gains validator_permit, this can be left empty and
# the miner auto-discovers via the metagraph.
export RELIQUARY_VALIDATOR_URL=http://86.38.238.30:8080

# Validator-only (left empty for miner)
export RELIQUARY_EXTERNAL_IP=
export RELIQUARY_EXTERNAL_PORT=

# R2 / S3 (validator-only; safe to leave dummy on miner)
export R2_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
export R2_ACCOUNT_ID=dummy
export R2_ACCESS_KEY_ID=
export R2_SECRET_ACCESS_KEY=
export R2_REGION=us-east-1
export R2_BUCKET_ID=grail-catalyst-test

# State HMAC (validator-only)
export GRAIL_STATE_HMAC_KEY=catalyst-local-test-hmac

# Smart-miner knobs (engine-side defaults are fine; these are
# convenience env overrides if you want to tune without code changes).
export RELIQUARY_GEN_BATCH_PROMPTS=2
export RELIQUARY_PRESCREEN_ROLLOUTS=8
export RELIQUARY_PRESCREEN_MAX_TOKENS=1024
export RELIQUARY_PREGEN_CAPACITY=48
export RELIQUARY_SHARE_MODEL=1

export PYTHONUNBUFFERED=1

# Supabase persistence — when set, miner hydrates pregen queue and prompt
# outcomes from a Supabase project. Leave empty to disable.
# Submitter-only mode. When set to 1, this miner stops running its own
# local prescreen+full-gen and only submits batches that some other
# machine wrote into Supabase pregen_batches (via scripts/prep_dataset.py
# running there). The submit worker still drains the queue every window;
# state poller still hydrates from Supabase on every ckpt advance.
# Leave OFF (default) for self-contained gen+submit operation.
# export RELIQUARY_DISABLE_LOCAL_GEN=1

# When set, the local pregen worker uses vLLM 0.20.x for generation
# (~2-3x throughput vs transformers.generate). GRAIL sketches still
# run on the HF model (vLLM doesn't expose per-layer hidden states).
# Two model instances on the GPU: vLLM with gpu_mem_util=0.50, HF
# with ~8 GB for Qwen3-4B in bf16. Comfortable on 80+ GB cards.
# Risk: ckpt reload destroys + rebuilds the vLLM instance (~30-60s).
export RELIQUARY_USE_VLLM=1
# vLLM 0.20.2 on CUDA only registers FLASH_ATTN/FLASHINFER/TRITON_ATTN/
# FLEX_ATTENTION — TORCH_SDPA isn't available, so we can't match HF's
# sdpa kernel. The vLLM↔HF p(EOS) divergence (~5-10x on EOS positions)
# is absorbed by the EOS guard threshold below — tune up if preverify
# low_p_stop rejects persist, tune down if rollouts cap-truncate.
# EOS ids for Qwen3-Instruct: <|im_end|>=151645 and <|endoftext|>=151643
# (both listed in generation_config.eos_token_id). Required by the
# VllmV1EosGuard logits processor registered in cli/main.py.
export RELIQUARY_VLLM_EOS_IDS=151643,151645
export RELIQUARY_VLLM_EOS_THRESHOLD=0.008
# Reduce CUDA allocator fragmentation when HF sketch + vLLM gen
# co-reside on the same GPU. Without this, ~8 GiB stays "reserved
# but unallocated" after a few sketch forwards and OOMs the next
# 5 GiB log_softmax allocation even though total free memory is
# nominally enough.
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

export RELIQUARY_SUPABASE_URL=https://fwyglzgpodpflkdoibdh.supabase.co
export RELIQUARY_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ3eWdsemdwb2RwZmxrZG9pYmRoIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3OTcyNTM1NywiZXhwIjoyMDk1MzAxMzU3fQ.LsqslSQ1ruA7vuef4MUKMOhrun64eQR7aymaQMi3XGg
