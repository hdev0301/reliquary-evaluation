NEXT_PUBLIC_DEFAULT_HOTKEY=5HGr6joke42gGZxMHsDTuJEepnmbaihM7KdUwVtq2kA6TNAN
RELIQUA_BASE_URL=https://www.reliqua.ai

# Optional: Vercel protection-bypass token used by reliqua.ai.
# When reliqua.ai's Vercel deployment serves a Security Checkpoint (403 with
# X-Vercel-Mitigated: challenge), set this to the bypass secret you've been
# issued. The proxy will send it as `x-vercel-protection-bypass` and the
# challenge is skipped. Leave empty if you don't have one.
# RELIQUA_BYPASS_TOKEN=

# Optional: static reliqua.ai cookie header to bypass the Vercel challenge
# WITHOUT a token. Normally supplied dynamically by the companion browser
# extension (see ./extension) via /api/bypass-cookie, but you can also paste a
# cleared cookie string here (DevTools > Application > Cookies > reliqua.ai).
# If set, this takes precedence over the extension-supplied cookie.
# RELIQUA_COOKIE=
