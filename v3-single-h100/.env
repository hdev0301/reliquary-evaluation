# Reliquary runtime environment (copy to scripts/.env and fill in)
export BT_NETWORK=finney
export NETUID=81

# Wallet used by the process — validator and miner usually use different ones
export BT_WALLET_NAME=ronnywebdev
export BT_HOTKEY=hdev0301

# Model to serve / mine with. Any HuggingFace causal LM checkpoint.
export RELIQUARY_CHECKPOINT=Qwen/Qwen3-4B-Instruct-2507

# Attention kernel. Use "sdpa" on boxes without flash-attn compiled,
# "flash_attention_2" for full-speed production. Validator runs sdpa
# (no flash_attn) — match it exactly via the GRAIL_ATTN_IMPL var that
# reliquary.constants actually reads.
export RELIQUARY_ATTN_IMPL=sdpa
export GRAIL_ATTN_IMPL=sdpa

# Hugging Face token (for downloading checkpoints from the validator's repo).
export HF_TOKEN=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
export HUGGING_FACE_HUB_TOKEN=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

# Pin install dir to where the repo actually lives (launch_miner.sh default
# is /root/Catalyst, which is wrong on this box).
export RELIQUARY_INSTALL_DIR=/root/reliquary

# Cap miner generation length. Protocol ceiling is 8192; lower this for fast
# smoke tests (e.g. 64 finishes a window in seconds on GPT-2).
export RELIQUARY_MAX_NEW_TOKENS=8192

# Skip drand beacon verification (no `blst` package on pypi). Only safe for
# local tests — production validators MUST verify beacons.
export RELIQUARY_USE_DRAND=1

# Multi-prompt batched generation. K prompts × M=8 rollouts per .generate().
# K=1 = single-prompt batch=8 per call (reference miner behaviour).
#
# Counter-intuitively, K=1 is BETTER for winning races than K>1:
#   * K=4 batches 32 sequences; .generate() waits for the slowest of 32.
#     One slow rollout (running to 8192) drags out all 32. Lat-to-first
#     in-zone batch is dominated by the worst-case row.
#   * K=1 batches just 8 sequences. Lat-to-first = slowest of 8, much
#     shorter on average. First-ready latency is what gets us into a
#     window before the seal, throughput is irrelevant if we can't win
#     a slot.
#
# Throughput is secondary: more total candidates produced per minute
# doesn't help if every one of them lands too late.
export RELIQUARY_GEN_BATCH_PROMPTS=1

# Miner-only: explicit validator URL. Empty = use chain metagraph discovery.
export RELIQUARY_VALIDATOR_URL=http://86.38.238.30:8080

# Validator-only: public IP and port this validator is reachable at. If set,
# the validator calls subtensor.serve_axon(ip, port) at startup so miners
# discover it through the metagraph. Leave empty to skip (miners then need
# RELIQUARY_VALIDATOR_URL on their side). Must point at a routable endpoint:
# a real VPS public IP, or a port-forward that actually carries request bodies
# (Targon's 30749→8888 mapping silently drops >10KB and should not be used).
export RELIQUARY_EXTERNAL_IP=
export RELIQUARY_EXTERNAL_PORT=

# Dataset upload bucket. Set these once and forget; storage.py reads them.
export R2_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
export R2_ACCOUNT_ID=dummy
export R2_ACCESS_KEY_ID=
export R2_SECRET_ACCESS_KEY=
export R2_REGION=us-east-1
export R2_BUCKET_ID=grail-catalyst-test

# HMAC key used by storage.py for validator-state integrity. Any stable string.
export GRAIL_STATE_HMAC_KEY=catalyst-local-test-hmac

export PYTHONUNBUFFERED=1
