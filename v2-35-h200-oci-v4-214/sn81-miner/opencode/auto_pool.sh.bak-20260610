#!/bin/bash
# auto_pool.sh — keep the OpenCode miner running on a FRESH curated in-zone pool.
#
# WHY: in-zone prompts are a permanently-depleting resource (won prompts cool for
# 1,000,000 windows => forever) AND the checkpoint republishes ~every 10 windows
# (scatter shifts). A static curated pool therefore goes stale two ways: drift +
# depletion. This supervisor rebuilds the pool when needed and (re)launches the miner
# on it, so the miner always mines network-fresh, checkpoint-current in-zone prompts.
#
# SINGLE H200: build and mine CANNOT overlap (two vLLM instances OOM). So each refresh
# PAUSES mining. The nvidia reconstruction is cached one-time (data/oci_cases_cache.json),
# so a refresh is generation+grading only (~30-40 min for 2000 candidates).
#
# REFRESH TRIGGER (whichever first) — tuned to avoid wasteful every-checkpoint rebuilds:
#   * the validator checkpoint advanced >= REFRESH_EVERY_CKPTS times since the last build, OR
#   * the FRESH (non-cooled) pool count drops below MIN_FRESH (~MIN_FRESH/8 windows left).
# A hard MIN_REFRESH_INTERVAL_S floor prevents thrashing.
#
# USAGE:  bash /root/sn81-miner/opencode/auto_pool.sh        # run under tmux/nohup
#   tune via env: REFRESH_EVERY_CKPTS=3 MIN_FRESH=64 POOL_MAX_CANDIDATES=2000 POOL_M=10
set -u

SN81="${SN81:-/root/sn81-miner}"
REPO="${REPO:-/root/reliquary}"
VURL="${VALIDATOR_URL:-http://86.38.238.30:8080}"
POOL="$SN81/data/inzone_pool_opencode.json"
STATE="$SN81/data/auto_pool_state.json"          # sidecar: {built_ckpt_n}
SCREENED="$SN81/data/screened_opencode.json"     # idxs already screened on the CURRENT checkpoint (chunk dedup)
LOG="$SN81/logs/auto_pool.log"
MODEL_CACHE="/root/.cache/huggingface/hub/models--R0mAI--reliquary-sn-v23/snapshots"

# CHUNKED INCREMENTAL pool building (vs one ~55min full rebuild): each refresh
# screens a SMALL chunk of NEW candidates on the current checkpoint (~12min) and
# APPENDS the scatterers, so the miner earns between chunks and the pool grows.
# Cases are checkpoint-independent (cached), so a chunk only pays generate+grade.
# BROAD (no strategy-a): a STRONG model solves easy prompts (sigma=0) — the rare
# scatterers live at its harder competence EDGE, which broad screening reaches.
REFRESH_EVERY_CKPTS="${REFRESH_EVERY_CKPTS:-1}"   # ANY checkpoint advance resets pool+screened (scatter is checkpoint-specific)
MIN_FRESH="${MIN_FRESH:-32}"                       # chunk-append when fewer than this many non-cooled pool prompts remain
MIN_REFRESH_INTERVAL_S="${MIN_REFRESH_INTERVAL_S:-600}"   # chunks are ~12min; floor just bounds back-to-back thrash
POLL_S="${POLL_S:-120}"
CHUNK_CANDIDATES="${CHUNK_CANDIDATES:-200}"        # candidates screened PER CHUNK (~10-12min build at M=32; keeps mining pause short)
MIN_POOL_TARGET="${MIN_POOL_TARGET:-40}"           # LOW: aggressive bootstrap starves mining (each chunk = stop+build+vLLM reload).
                                                   # A ~40+ pool is enough to mine; let it run STEADILY and only rebuild on
                                                   # depletion (fresh<MIN_FRESH) or self-heal (dead pool). Maximizes mining uptime.
POOL_M="${POOL_M:-32}"                             # BALANCE depth vs build-speed: M=12 over-keeps (94% kept, dead pool @ckpt907);
                                                   # M=64 matches the miner exactly but builds ~30min (miner idle too long).
                                                   # M=32 kills most small-sample jitter (~17% keep) AND builds ~12min. self-heal
                                                   # (dead_pool trigger) + gate 0.45 cover any residual over-keep on a bad ckpt.
BUILD_MAX_NEW_TOKENS="${BUILD_MAX_NEW_TOKENS:-1280}"  # MATCH the miner's MAX_NEW_TOKENS so build-scatter predicts mine-scatter

log(){ echo "$(date -u +%H:%M:%S) | $*" | tee -a "$LOG"; }

# --- helpers (python one-liners against /state and the pool) -------------------
cur_ckpt_n(){ "$REPO/.venv/bin/python" - "$VURL" <<'PY'
import sys,httpx
try: print(httpx.get(sys.argv[1]+"/state",timeout=10).json().get("checkpoint_n",-1))
except Exception: print(-1)
PY
}
fresh_pool_count(){ "$REPO/.venv/bin/python" - "$VURL" "$POOL" <<'PY'
import sys,json,httpx
try:
    pool=set(json.load(open(sys.argv[2])))
    cd=set(httpx.get(sys.argv[1]+"/state",timeout=10).json().get("cooldown_prompts",[]))
    print(len(pool-cd))
except Exception: print(-1)
PY
}
latest_snapshot(){ ls -dt "$MODEL_CACHE"/*/ 2>/dev/null | head -1; }   # the one the miner last loaded (present locally)
built_ckpt(){ [ -f "$STATE" ] && "$REPO/.venv/bin/python" -c "import json;print(json.load(open('$STATE')).get('built_ckpt_n',-1))" 2>/dev/null || echo -1; }
pool_size(){ [ -s "$POOL" ] && "$REPO/.venv/bin/python" -c "import json;print(len(json.load(open('$POOL'))))" 2>/dev/null || echo 0; }
screened_count(){ [ -s "$SCREENED" ] && "$REPO/.venv/bin/python" -c "import json;print(len(json.load(open('$SCREENED'))))" 2>/dev/null || echo 0; }

stop_miner(){
  local mpid; mpid=$(pgrep -f "reliquary.cli.main mine" | head -1)
  if [ -n "$mpid" ]; then pkill -9 -P "$mpid" 2>/dev/null; kill -9 "$mpid" 2>/dev/null; fi
  pkill -9 -f "reliquary.cli.main mine" 2>/dev/null; pkill -9 -f "EngineCore" 2>/dev/null
  sleep 6
}

build_pool(){   # builds ONE small CHUNK and APPENDS to the pool (incremental)
  local snap; snap="$(latest_snapshot)"
  [ -z "$snap" ] && { log "BUILD SKIP: no local snapshot found"; return 1; }
  local cn bn; cn=$(cur_ckpt_n); bn=$(built_ckpt)
  # Scatter is checkpoint-specific: on ANY checkpoint advance, drop the pool +
  # screened set so we rescreen fresh on the new checkpoint (cases stay cached).
  if [ "$cn" -ge 0 ] && [ "$bn" -ge 0 ] && [ "$cn" != "$bn" ]; then
    log "checkpoint advanced ($bn -> $cn) -> reset pool + screened (rescreen fresh)"
    rm -f "$POOL" "$SCREENED"
  fi
  log "CHUNK build on $(basename "$snap") (+${CHUNK_CANDIDATES} cand, m=$POOL_M, BROAD+append; pool=$(pool_size) screened=$(screened_count))"
  ( cd "$REPO" && set -a && source scripts/.env 2>/dev/null; set +a
    export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
    "$REPO/.venv/bin/python" "$SN81/opencode/build_opencode_pool.py" \
      --checkpoint "$snap" --max-candidates "$CHUNK_CANDIDATES" --m "$POOL_M" \
      --strict-zone --max-new-tokens "$BUILD_MAX_NEW_TOKENS" \
      --append --screened-file "$SCREENED" \
      --gpu-mem-util 0.85 --out "$POOL" ) >> "$SN81/logs/build_pool.log" 2>&1
  local rc=$?
  if [ $rc -ne 0 ]; then log "CHUNK FAILED (rc=$rc) — keeping previous pool"; return 1; fi
  # record the checkpoint this chunk screened on (used for the reset check above)
  "$REPO/.venv/bin/python" -c "import json;json.dump({'built_ckpt_n':$cn},open('$STATE','w'))"
  log "CHUNK done: pool=$(pool_size) idxs (screened=$(screened_count)/50000 this ckpt)"
}

start_miner(){
  log "MINER (re)launch on broad sigma-curated pool (consensus-strict, oversample=${MINER_OVERSAMPLE:-32})"
  # MINER PARAMS (accepts are dominated by the SEAL RACE: batch_filled at over=0/late fires):
  #  * OVERSAMPLE 32 (was 64): deeper oversample SLOWED group assembly -> PRESTAGE had no
  #    group ready at window-open -> we fired late (t_since 100-380s, over=100+) -> batch_filled.
  #    32 assembles ~2x faster -> more pre-staged on-time fires. The pool is now PARITY-graded
  #    (its prompts are reliable scatterers), so 32 is enough to reproduce scatter; it also
  #    MATCHES the build POOL_M=32 (same-depth -> build sigma8 ~= mine sigma8). Matches the
  #    known-good reference miner (CONSENSUS oversample 32).
  #  * TARGET_K is INERT: consensus.select_max_std searches EVERY split for the max-std 8.
  #  * SIGMA_MIN 0.43 = validator floor. MAX_NEW_TOKENS 1280: short completions clear GRAIL
  #    faster = win more of the over=0 speed race. stale_round guard lives in engine.py.
  POOL="$POOL" MODE=opencode CONSENSUS_STRICT=1 CONSENSUS=1 \
    TARGET_K="${MINER_TARGET_K:-6}" CONSENSUS_OVERSAMPLE="${MINER_OVERSAMPLE:-32}" \
    RELIQUARY_CONSENSUS_SIGMA_MIN="${MINER_SIGMA_MIN:-0.43}" \
    GPU_MEM="${MINER_GPU_MEM:-0.72}" CONSENSUS_WORKERS="${CONSENSUS_WORKERS:-22}" \
    MAX_NUM_SEQS="${MINER_MAX_NUM_SEQS:-512}" \
    bash "$SN81/bin/run_miner.sh" >> "$LOG" 2>&1
}

# --- main loop ----------------------------------------------------------------
log "=== auto_pool supervisor start (chunked: +${CHUNK_CANDIDATES}/chunk, target=$MIN_POOL_TARGET, min_fresh=$MIN_FRESH) ==="
[ -s "$POOL" ] || { log "no pool yet -> first chunk"; stop_miner; build_pool; }
start_miner
last_refresh=$(date +%s)
while true; do
  sleep "$POLL_S"
  if ! pgrep -f "reliquary.cli.main mine" >/dev/null; then
    # miner not up. If the pool is empty/invalid (e.g. just reset on a new ckpt and
    # the first chunk found no scatterers), run_miner.sh aborts on the empty pool ->
    # seed a chunk instead of relaunch-looping forever.
    if [ "$(pool_size)" -lt 1 ]; then
      log "miner down + empty pool -> seed chunk"; stop_miner; build_pool; start_miner; last_refresh=$(date +%s); continue
    fi
    log "miner died -> relaunch"; start_miner; continue
  fi
  cn=$(cur_ckpt_n); bn=$(built_ckpt); fresh=$(fresh_pool_count); psize=$(pool_size)
  now=$(date +%s); since=$((now - last_refresh))
  drift=$(( cn>=0 && bn>=0 ? cn-bn : 0 ))
  need=0; why=""
  [ "$cn" -ge 0 ] && [ "$bn" -ge 0 ] && [ "$drift" -ge "$REFRESH_EVERY_CKPTS" ] && { need=1; why="ckpt_advance(drift=$drift)"; }
  [ "$psize" -lt "$MIN_POOL_TARGET" ] && [ "$(screened_count)" -lt 45000 ] && { need=1; why="${why:+$why,}bootstrap(pool=$psize<$MIN_POOL_TARGET)"; }
  [ "$fresh" -ge 0 ] && [ "$fresh" -lt "$MIN_FRESH" ] && { need=1; why="${why:+$why,}depleted(fresh=$fresh)"; }
  # SELF-HEAL a POISONED/DEAD pool: a full+fresh pool whose prompts the miner can't
  # curate (kept=0 across many recent pregen batches) reads "healthy" to the size/fresh
  # triggers above but ships ~nothing (observed ckpt 907: pool=568 fresh=566, all sigma=0).
  # Detect sustained kept-starvation and force a rebuild so it can't stay stuck for hours.
  dead=$(tail -300 "$SN81/logs/miner.log" 2>/dev/null | grep -c "pregen batch detail: kept=0")
  [ "$dead" -ge 12 ] && { need=1; why="${why:+$why,}dead_pool(kept0x$dead)"; }
  if [ "$need" = 1 ] && [ "$since" -ge "$MIN_REFRESH_INTERVAL_S" ]; then
    log "CHUNK trigger: $why (built@$bn now@$cn) -> pause+chunk"
    stop_miner; build_pool; start_miner; last_refresh=$(date +%s)
  else
    log "ok: ckpt=$cn built@$bn pool=$psize fresh=$fresh (no chunk)"
  fi
done
