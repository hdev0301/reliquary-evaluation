# OpenCode optimized miner — copy to mining/opencode/.env, edit, then `source` it.

# --- wallet / chain ---
export BT_WALLET_NAME=my_miner
export BT_HOTKEY=default
# export BT_WALLET_PATH=/root/.bittensor/wallets
export BT_NETWORK=finney
export NETUID=81

# Pin the validator during the launch phase (see docs/mining.md). Drop once the
# owner validator holds validator_permit and is auto-discoverable.
export RELIQUARY_VALIDATOR_URL=http://<owner-validator-ip>:8888

# --- hugging face ---
# Token for checkpoint pulls (snapshot_download / hf_hub_download). Required if
# the checkpoint repo is gated or to avoid unauthenticated rate limits.
export HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export HUGGING_FACE_HUB_TOKEN=$HF_TOKEN

# --- model / GPUs ---
export RELIQUARY_CHECKPOINT=Qwen/Qwen3.5-4B
export RELIQUARY_GEN_GPU=0          # vLLM generation device
export RELIQUARY_PROOF_GPU=1        # HF GRAIL proof device (use 0 on a single-GPU box)
export RELIQUARY_VLLM_GPU_MEM_UTIL=0.55
export RELIQUARY_VLLM_MAX_MODEL_LEN=12288
# Separate vLLM venv python (built by mining/setup.sh). The proof venv (.venv)
# stays on the validator-matched torch 2.7.0 / transformers 5.9.0 stack; vLLM
# runs as a worker here on its own torch. run.sh sets this automatically.
export RELIQUARY_VLLM_PYTHON=.venv-vllm/bin/python

# --- frontier oracle (built once, offline) ---
export RELIQUARY_OCI_ORACLE_PATH=mining/state/opencode_oracle.json.gz
# On an isolated lab box without gVisor/runsc, allow the unsandboxed local grader:
# export RELIQUARY_ALLOW_UNSANDBOXED_GRADER=1

# --- pregen pool ---
export RELIQUARY_POOL_TARGET_DEPTH=24
export RELIQUARY_POOL_MAX_DEPTH=48
export RELIQUARY_SCREEN_BATCH_PROMPTS=8

# --- zone targeting (well-trained model: most prompts are 0/8 or 8/8) ---
export RELIQUARY_SIGMA_MARGIN=0.0   # extra headroom over SIGMA_MIN=0.43
export RELIQUARY_TARGET_K_LO=3      # keep groups the proxy scores k in [lo, hi] /8
export RELIQUARY_TARGET_K_HI=5

# --- fire / drand race ---
export RELIQUARY_DRAND_BOUNDARY_MARGIN_S=0.4
export RELIQUARY_MAX_FIRE_PER_WINDOW=8   # never above MAX_SUBMISSIONS_PER_HOTKEY_PER_WINDOW
export RELIQUARY_MIN_EOS_PROB=0.015      # drop groups whose EOS prob risks BAD_TERMINATION (0 disables)
export RELIQUARY_STATE_POLL_INTERVAL_S=0.25
export RELIQUARY_VERDICT_POLL_INTERVAL_S=5.0
