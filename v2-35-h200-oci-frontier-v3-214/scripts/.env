# Reliquary runtime environment — generated from scripts/.env.example.
# This file is gitignored (.gitignore:11). Keep secrets (HF_TOKEN, R2 keys) here,
# NOT in the tracked scripts/.env.example template.

# Where the repo + venv live (launch_miner.sh cd's here; default is /root/Catalyst).
export RELIQUARY_INSTALL_DIR=/root/reliquary

# vLLM EngineCore must spawn (not fork) — the miner parent inits CUDA before vLLM,
# and a forked child fails "Cannot re-initialize CUDA in forked subprocess".
export VLLM_WORKER_MULTIPROC_METHOD=spawn

export BT_NETWORK=finney
export NETUID=81

# Wallet used by the process — validator and miner usually use different ones
export BT_WALLET_NAME=ronnywebdev
export BT_HOTKEY=ronnywebdev_hotkey

# Model to serve / mine with. The miner auto-resolves the validator's published
# checkpoint from /state; this is the boot fallback, so point it at the real
# base model (NOT the gpt2 smoke-test default).
export RELIQUARY_CHECKPOINT=Qwen/Qwen3.5-4B

# Attention kernel. ONLY GRAIL_ATTN_IMPL is read by the code (constants.py:56);
# it drives the HF proof model AND the validator's verification forward
# (service.py:165), so flash_attention_2 = matched to the validator = canonical.
# Measured flash<->sdpa drift on this H200 is within the GRAIL tolerance band
# (sketch max ~1417 vs tol ~5075; logprob median dev 0.0), so sdpa is a safe
# fallback if flash-attn can't be built — but flash is the exact-match default.
# RELIQUARY_ATTN_IMPL is a DEAD variable — read by no code (verified across the
# tree + installed pkg). Set to sdpa only to mirror the reference miner's .env;
# it has ZERO effect. A miner "using sdpa" via this var is really on flash.
export GRAIL_ATTN_IMPL=flash_attention_2
export RELIQUARY_ATTN_IMPL=sdpa

export HF_TOKEN=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
export HUGGING_FACE_HUB_TOKEN=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

# Cap miner generation length. Protocol ceiling is 8192. This checkpoint is a
# long-CoT reasoner: terminating (EOS) completions on GSM8K-style prompts run up
# to ~1004 tokens (p75≈313), so 1024 captures them while cutting ramblers cheaply.
# Higher caps just burn tokens on prompts that never terminate.
export RELIQUARY_MAX_NEW_TOKENS=1024

# Over-generation: sample this many completions per prompt, keep the first 8 that
# terminate with EOS (format-selection, not reward-shaping). Needed because the
# per-rollout EOS-termination rate is low.
export RELIQUARY_OVERSAMPLE=64

# Only mine these OMI problem_source values. The long-CoT checkpoint only
# terminates on short GSM8K-style problems; hard MATH problems ramble forever
# and never form a valid group. (Winners in the archive are all augmented_gsm8k.)
export RELIQUARY_PROMPT_SOURCES=gsm8k,augmented_gsm8k

# Skip drand beacon verification (no `blst` package on pypi). Only safe for
# local tests — production validators MUST verify beacons.
export RELIQUARY_USE_DRAND=1

# Miner-only: explicit validator URL. Empty = use chain metagraph discovery.
export RELIQUARY_VALIDATOR_URL=http://86.38.238.30:8080

# Validator-only: public IP and port this validator is reachable at. If set,
# the validator calls subtensor.serve_axon(ip, port) at startup so miners
# discover it through the metagraph. Leave empty to skip (miners then need
# RELIQUARY_VALIDATOR_URL on their side). Must point at a routable endpoint:
# a real VPS public IP, or a port-forward that actually carries request bodies
# (Targon's 30749→8888 mapping silently drops >10KB and should not be used).
export RELIQUARY_EXTERNAL_IP=
export RELIQUARY_EXTERNAL_PORT=

# Dataset upload bucket. Set these once and forget; storage.py reads them.
export R2_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
export R2_ACCOUNT_ID=dummy
export R2_ACCESS_KEY_ID=
export R2_SECRET_ACCESS_KEY=
export R2_REGION=us-east-1
export R2_BUCKET_ID=grail-catalyst-test

# HMAC key used by storage.py for validator-state integrity. Any stable string.
export GRAIL_STATE_HMAC_KEY=catalyst-local-test-hmac

export PYTHONUNBUFFERED=1

# ---- CUDA toolkit for flashinfer JIT (added to fix Qwen3.5 GDN linear-attn
# kernel compile). The cu130 torch wheels ship CUDA *runtime* only; flashinfer's
# JIT (flashinfer/jit/cpp_ext.py) needs nvcc + headers + lib64 at $CUDA_HOME.
# Installed via `cuda-toolkit-13-0` (matches torch cuda 13.0 / nvrtc 13.0.88).
export CUDA_HOME=/usr/local/cuda
export PATH=/usr/local/cuda/bin:$PATH
